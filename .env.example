# ─── Site ────────────────────────────────────────────────────────────────────
# Public URL of the deployed site (no trailing slash).
# Update content/shared.ts → shared.url to match.
NEXT_PUBLIC_SITE_URL=https://example.com

# ─── Contact Form ────────────────────────────────────────────────────────────
# Resend API key — https://resend.com
# Used in app/api/contact/route.ts
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Email address that receives contact form submissions
CONTACT_EMAIL=hello@example.com

# ─── Analytics ───────────────────────────────────────────────────────────────
# Vercel Analytics is zero-config on Vercel deployments.
# Add NEXT_PUBLIC_ANALYTICS_ID only if using a self-hosted solution.
# NEXT_PUBLIC_ANALYTICS_ID=

# ─── Optional third-party ────────────────────────────────────────────────────
# Calendly or Cal.com booking link — used in CTA / contact components
# NEXT_PUBLIC_BOOKING_URL=https://calendly.com/yourname
